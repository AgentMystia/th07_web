{
  "name": "touhou-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "check": "tsc --noEmit",
    "build": "esbuild src/main.ts --bundle --format=iife --outfile=dist/th07.js --sourcemap",
    "dev": "esbuild src/main.ts --bundle --format=iife --outfile=dist/th07.js --sourcemap --watch --servedir=.",
    "generate-data": "node scripts/generate-th07-data.mjs",
    "generate-bgm": "node scripts/split-th07-bgm.mjs",
    "test": "node --test tests/*.test.mjs",
    "replay:verify": "node scripts/replay-verify.mjs",
    "replay:inspect": "node scripts/replay-inspect.mjs",
    "replay:browser": "node scripts/dev-replay.mjs",
    "prepare-pages": "node scripts/prepare-pages.mjs",
    "deploy": "node scripts/deploy-pages.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "esbuild": "^0.25.0",
    "pngjs": "^7.0.0",
    "typescript": "^5.6.0"
  }
}
